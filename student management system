#include <iostream>
#include <iomanip>
#include <string>
using namespace std;

struct student
    {
        string name;
        string course;
        int IDnum;
        float cgpa;
    };

void introMessage(char&);
void addStudent(student[], int&, char&);
void displayStudent(student[], int);
void searchStudent(student[], int);
void updateStudent(student[], int);
void deleteStudent(student[], int&);
void exitProgram();

int main()
{
    student studNumber[100];
    int index = 0;
    char start, choose;

    introMessage(start);
    
    do
    {
    	addStudent(studNumber, index, choose);
    	
    	cout << "Do you want to add another student ?";
        cin >> choose;
        choose = toupper(choose);
        cin.ignore();
        
	}while(choose == 'Y');
  	
    displayStudent(studNumber, index);
    searchStudent(studNumber, index);
    updateStudent(studNumber, index);
    deleteStudent(studNumber, index);
    exitProgram();
    
    return 0;

}

